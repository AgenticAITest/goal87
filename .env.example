# Copy to .env and fill in real values. Never commit .env.
# This file is read by docker-compose at build and runtime.

# ── football-data.org ────────────────────────────────────────────────────────
FD_API_TOKEN=0fe9f577feb64cb0be35e5453ae9af58   # replace with real token

# ── Supabase (pildun project — NOT the TOP87 alumni project) ─────────────────
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Frontend build vars (baked into the Vite static bundle at compile time) ──
# Must duplicate the Supabase vars above with the VITE_ prefix so Vite picks them up.
VITE_SUPABASE_URL=https://YOURREF.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_WORKER_URL=https://bola.top87.id/api/worker
